% predicate_canonical: dang_ky_doanh_nghiep
% normalization_status: full
% source_text: Hồ sơ đăng ký doanh nghiệp được tiếp nhận để nhập thông tin vào Hệ thống thông tin quốc gia về đăng ký doanh nghiệp khi có đủ các điều kiện sau đây:
applicability_condition(dang_ky_doanh_nghiep, khi_co_du_cac_dieu_kien_sau_day) :- applies_if(dang_ky_doanh_nghiep, khi_co_du_cac_dieu_kien_sau_day).

% rule_id: RULE_ND168_D31_K3_E000266_H1509A1A35C79__4bce78214f31d1
