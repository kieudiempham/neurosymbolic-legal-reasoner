% predicate_canonical: cap_giay_chung_nhan_dang_ky_doanh_nghiep
% normalization_status: partial
% source_text: Các cổ đông phải thanh toán đủ số cổ phần đã đăng ký mua trong thời hạn 90 ngày kể từ ngày được cấp Giấy chứng nhận đăng ký doanh nghiệp, trừ trường hợp Điều lệ công ty hoặc hợp đồng đăng ký mua cổ phần quy định một thời hạn khác ngắn hơn. 
% --- reasoning-clean produced by scripts/clean_rulebase_problog_reasoning_clean.py ---

legal_effect(co_quan_dang_ky_kinh_doanh, duoc_cap_giay_chung_nhan_dang_ky_doanh_nghiep) :- unless(tru_truong_hop_dieu_le_cong_ty_hoac_hop_dong_dang_ky_mua_co_phan_quy_dinh_mot_thoi_han_khac_ngan_hon).

% rule_id: RULE_LUATDN_D122_K5_E000113_H7EB788490A1F__677a939a82a955
