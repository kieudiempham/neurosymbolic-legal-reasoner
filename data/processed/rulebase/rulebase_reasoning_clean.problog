% normalization_status: full
% source_text: Sau khi tiếp nhận hồ sơ đăng ký doanh nghiệp, Cơ quan đăng ký kinh doanh cấp tỉnh trao giấy tiếp nhận hồ sơ và hẹn trả kết quả cho người nộp hồ sơ.
authority_action(co_quan_dang_ky_kinh_doanh_cap_tinh, trao_giay_tiep_nhan_ho_so, ho_so_dang_ky_doanh_nghiep) :- applies_if(trao_giay_tiep_nhan_ho_so, khi_tiep_nhan_ho_so_dang_ky_doanh_nghiep_co_quan_dang_ky_kinh_doanh),
    exception_applies(trao_giay_tiep_nhan_ho_so_va_hen_tra_ket_qua_cho_nguoi_nop_ho_so).

