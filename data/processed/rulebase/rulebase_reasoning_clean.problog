dossier_item(dang_ky_doanh_nghiep, van_ban_de_nghi_dung_thuc_hien_thu_tuc_dang_ky_doanh_nghiep) :- applies_if(dang_ky_doanh_nghiep, khi_ho_so_dang_ky_doanh_nghiep_chua_duoc_chap_thuan_tren_he_thong_thong_tin_quoc_gia_ve_dang_ky_doanh_nghiep).

