% predicate_canonical: kem
% normalization_status: full
% source_text: Trường hợp ủy quyền cho cá nhân thực hiện thủ tục đăng ký doanh nghiệp, kèm theo hồ sơ đăng ký doanh nghiệp phải có văn bản ủy quyền cho cá nhân thực hiện thủ tục liên quan đến đăng ký doanh nghiệp. Văn bản ủy quyền này không bắt buộc phải 
dossier(kem, '[\'văn bản ủy quyền cho cá nhân thực hiện thủ tục đăng ký doanh nghiệp\']') :-
    applies_if('Trường hợp ủy quyền cho cá nhân thực hiện thủ tục đăng ký doanh nghiệp'),
    expression_condition(truong_hop_uy_quyen_cho_ca_nhan_thuc_hien_thu_tuc_dang_ky_doanh_nghiep).

