% predicate_canonical: dang_ky
% normalization_status: partial
% source_text: Các cổ đông sáng lập phải cùng nhau đăng ký mua ít nhất 20% tổng số cổ phần phổ thông được quyền chào bán khi đăng ký thành lập doanh nghiệp.
applicability_condition(dang_ky, 'khi đăng ký thành lập doanh nghiệp.') :-
    applies_to(ap_dung_doi_voi_co_dong_sang_lap),
    raw_condition('khi đăng ký thành lập doanh nghiệp.'),
    expression_condition(khi_dang_ky_thanh_lap_doanh_nghiep).

