% rule_id: RULE_LUATDN_D175_K2_E000122_H3A810D8013F8__cecb075395e7d9
% rule_group_id: RG_LUATDN_D175_K2_KIEM_TOAN_THI_BAO_CAO_TAI_CH
% doc_code: 67/VBHN-VPQH
% source_ref: unit=UNIT_LUATDN_D175_K2_S1_SS1|doc_id=DOC_LUAT_DOANH_NGHIEP_67_VBHN_2025|chapter=V|section=|article=175|clause=2|point=|lines=1658-1658
% predicate_canonical: kiem_toan_thi_bao_cao_tai_chinh_hang_nam_cua_cong_ty_co_phan_phai_duoc_kiem_toan_truoc
% normalization_status: partial
% source_text: Đối với công ty cổ phần mà pháp luật yêu cầu phải kiểm toán thì báo cáo tài chính hằng năm của công ty cổ phần phải được kiểm toán trước khi trình Đại hội đồng cổ đông xem xét, thông qua.
applicability_condition(kiem_toan_thi_bao_cao_tai_chinh_hang_nam_cua_cong_ty_co_phan_phai_duoc_kiem_toan_truoc, 'Đối với công ty cổ phần mà pháp luật yêu cầu') :-
    applies_to(ap_dung_doi_voi_cong_ty_co_phan),
    raw_condition('Đối với công ty cổ phần mà pháp luật yêu cầu'),
    expression_condition(doi_voi_cong_ty_co_phan_ma_phap_luat_yeu_cau).

% rule_id: RULE_LUATDN_D186_K1_E000124_HFF0DAB317E93__e594e48a541eab
