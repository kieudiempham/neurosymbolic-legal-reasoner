% predicate_canonical: gui_ve_cong_ty_phieu_lay_y_kien
% normalization_status: partial
% source_text: Thời hạn phải gửi về công ty phiếu lấy ý kiến đã được trả lời;
obligation(cong_ty, gui_ve_cong_ty_phieu_lay_y_kien, da_duoc_tra_loi).

% rule_id: RULE_LUATDN_D149_K4_E000117_H791FDF195CF0__e9bb79707b2c9c
