% predicate_canonical: gui_cho_thanh_vien_cong_ty_truoc
% normalization_status: full
% source_text: Chương trình và tài liệu họp phải được gửi cho thành viên công ty trước khi họp. Tài liệu sử dụng trong cuộc họp liên quan đến quyết định về sửa đổi, bổ sung Điều lệ công ty, thông qua chiến lược phát triển công ty, thông qua báo cáo tài ch
applicability_condition(gui_cho_thanh_vien_cong_ty_truoc, 'khi họp. Tài liệu sử dụng trong cuộc họp liên quan đến quyết định về sửa đổi, bổ sung Điều lệ công ty, thông qua chiến lược phát triển công ty, thông qua báo cáo tài chính hằng năm, tổ chức lại hoặc giải thể công ty phải') :-
    applies_if('khi họp. Tài liệu sử dụng trong cuộc họp liên quan đến quyết định về sửa đổi, bổ sung Điều lệ công ty, thông qua chiến lược phát triển công ty, thông qua báo cáo tài chính hằng năm, tổ chức lại hoặc giải thể công ty phải'),
    expression_condition(khi_hop_tai_lieu_su_dung_trong_cuoc_hop_lien_quan_den_quyet_dinh_ve_sua_doi_bo_sung_dieu_le_cong_ty_thong_qua_chien_luoc_phat_trien_cong_ty_thong_qua_bao_cao_tai_chinh_hang_nam_to_chuc_lai_hoac_giai_the_cong_ty_phai).

