% rule_id: RULE_ND168_D118_K3_E000522_H0811C24751E0__7fb44d85940b04
% rule_group_id: RG_ND168_D118_K3_THONG_BAO
% doc_code: 168/2025/NĐ-CP
% source_ref: unit=UNIT_168_2025_N_CP_D118_K3_S1_SS1|doc_id=DOC_ND_DANG_KY_DOANH_NGHIEP_168_2025|chapter=IX|section=|article=118|clause=3|point=|lines=1063-1063
% predicate_canonical: thong_bao
% normalization_status: partial
% source_text: Trường hợp chi nhánh, văn phòng đại diện, địa điểm kinh doanh của doanh nghiệp khác tỉnh, thành phố trực thuộc trung ương nơi doanh nghiệp đặt trụ sở chính, doanh nghiệp phải thực hiện thủ tục đăng ký quy định tại khoản 1 Điều này trước khi
legal_effect(co_quan_dang_ky_kinh_doanh, cham_dut_hoat_dong) :-
    applies_to(ap_dung_doi_voi_chi_nhanh_van_phong_dai_dien),
    raw_condition('đối với chi nhánh, văn phòng đại diện, địa điểm kinh doanh'),
    expression_condition(doi_voi_chi_nhanh_van_phong_dai_dien_dia_diem_kinh_doanh).

% rule_id: RULE_ND168_D118_K3_E000341_H6839229D9C6F__6f008278ee22c6
% rule_group_id: RG_ND168_D118_K3_THUC_HIEN_THU_TUC
% doc_code: 168/2025/NĐ-CP
% source_ref: unit=UNIT_168_2025_N_CP_D118_K3_S1_SS1|doc_id=DOC_ND_DANG_KY_DOANH_NGHIEP_168_2025|chapter=IX|section=|article=118|clause=3|point=|lines=1063-1063
% predicate_canonical: thuc_hien_thu_tuc
% normalization_status: partial
% source_text: Trường hợp chi nhánh, văn phòng đại diện, địa điểm kinh doanh của doanh nghiệp khác tỉnh, thành phố trực thuộc trung ương nơi doanh nghiệp đặt trụ sở chính, doanh nghiệp phải thực hiện thủ tục đăng ký quy định tại khoản 1 Điều này trước khi
procedure_step(thuc_hien_thu_tuc, 'đăng ký quy định tại khoản 1 Điều này trước khi thực hiện thủ tục đăng ký hoạt động') :-
    applies_to(ap_dung_doi_voi_chi_nhanh_van_phong_dai_dien),
    raw_condition('Trường hợp chi nhánh, văn phòng đại diện, địa điểm kinh doanh của doanh nghiệp khác tỉnh, thành phố trực thuộc trung ương nơi doanh nghiệp đặt trụ sở chính, doanh nghiệp phải thực hiện thủ tục đăng ký quy định tại khoản'),
    expression_condition(truong_hop_chi_nhanh_van_phong_dai_dien_dia_diem_kinh_doanh_cua_doanh_nghiep_khac_tinh_thanh_pho_truc_thuoc_trung_uong_noi_doanh_nghiep_dat_tru_so_chinh_doanh_nghiep_phai_thuc_hien_thu_tuc_dang_ky_quy_dinh_tai_khoan).

% rule_id: RULE_ND168_D119_K6_E000524_HFB48B4CA7B56__118c9ebd980a65
% rule_group_id: RG_ND168_D119_K6_DANG_KY
% doc_code: 168/2025/NĐ-CP
% source_ref: unit=UNIT_168_2025_N_CP_D119_K6_S1_SS1|doc_id=DOC_ND_DANG_KY_DOANH_NGHIEP_168_2025|chapter=IX|section=|article=119|clause=6|point=|lines=1074-1074
% predicate_canonical: dang_ky
% normalization_status: full
% source_text: Khi nhận được hồ sơ của doanh nghiệp, Cơ quan đăng ký kinh doanh cấp tỉnh trao giấy tiếp nhận hồ sơ và hẹn trả kết quả, xem xét tính hợp lệ của hồ sơ và cấp Giấy chứng nhận đăng ký doanh nghiệp, Giấy chứng nhận đăng ký hoạt động chi nhánh, 
legal_effect(van_phong_dai_dien, cap_giay_chung_nhan_dang_ky_doanh_nghiep_giay_chung_nhan_dang_ky_hoat_dong_chi_nhanh_van_phong_dai_dien_giay_chung_nhan_dang_ky_dia_diem_kinh_doanh_giay_xac_nhan_ve_viec_thay_doi_noi_du) :-
    applies_to(ap_dung_doi_voi_chi_nhanh_van_phong_dai_dien),
    applies_if('Khi nhận được hồ sơ của doanh nghiệp, Cơ quan đăng ký kinh doanh'),
    expression_condition(khi_nhan_duoc_ho_so_cua_doanh_nghiep_co_quan_dang_ky_kinh_doanh).

