% predicate_canonical: dang_ky_doanh_nghiep
% normalization_status: full
% source_text: Cơ quan đăng ký kinh doanh thuộc Sở Tài chính tỉnh, thành phố trực thuộc trung ương cấp đăng ký doanh nghiệp đối với doanh nghiệp, chi nhánh, văn phòng đại diện, địa điểm kinh doanh có địa chỉ tại tỉnh, thành phố trực thuộc trung ương trong
applicability_condition(dang_ky_doanh_nghiep, 'đối với doanh nghiệp, chi nhánh, văn phòng đại diện, địa điểm kinh doanh có địa chỉ tại tỉnh, thành phố trực thuộc trung ương trong phạm vi địa phương') :-
    applies_to(ap_dung_doi_voi_chi_nhanh_van_phong_dai_dien),
    applies_if('đối với doanh nghiệp, chi nhánh, văn phòng đại diện, địa điểm kinh doanh có địa chỉ tại tỉnh, thành phố trực thuộc trung ương trong phạm vi địa phương'),
    unless('trừ trường hợp quy định tại điểm b khoản này'),
    expression_condition(doi_voi_doanh_nghiep_chi_nhanh_van_phong_dai_dien_dia_diem_kinh_doanh_co_dia_chi_tai_tinh_thanh_pho_truc_thuoc_trung_uong_trong_pham_vi_dia_phuong).

