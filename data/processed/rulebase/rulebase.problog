legal_effect(co_quan_dang_ky_kinh_doanh, thu_hoi_giay_chung_nhan_dang_ky_ho_kinh_doanh_dong_thoi_ra_thong_bao_ve_viec_ho_kinh_doanh_dang_lam) :-
    applies_if('trường hợp hộ kinh doanh bị thu hồi Giấy chứng nhận đăng ký hộ kinh doanh để thực hiện biện pháp cưỡng chế nợ thuế theo đề nghị của Cơ quan quản lý thuế'),
    unless('trừ trường hợp hộ kinh doanh bị thu hồi Giấy chứng nhận đăng ký hộ kinh doanh để thực hiện biện pháp cưỡng chế nợ thuế theo đề nghị của Cơ quan quản lý thuế'),
    expression_condition(truong_hop_ho_kinh_doanh_bi_thu_hoi_giay_chung_nhan_dang_ky_ho_kinh_doanh_de_thuc_hien_bien_phap_cuong_che_no_thue_theo_de_nghi_cua_co_quan_quan_ly_thue).

