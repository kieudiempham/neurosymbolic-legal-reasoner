% predicate_canonical: tiep_nhan_them_thanh_vien_hop_danh
% normalization_status: full
% source_text: Công ty có thể tiếp nhận thêm thành viên hợp danh hoặc thành viên góp vốn; việc tiếp nhận thành viên mới của công ty phải được Hội đồng thành viên chấp thuận.
permission(cong_ty, tiep_nhan_them_thanh_vien_hop_danh, null).

% rule_id: RULE_LUATDN_D186_K2_E000127_H2FC30FD46A92__b5a3d6663421fc
% rule_group_id: RG_LUATDN_D186_K2_NOP_DU_SO_VON_CAM_KET_GOP
