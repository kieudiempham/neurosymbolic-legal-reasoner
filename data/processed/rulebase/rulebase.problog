% rule_id: RULE_ND168_D57_K3_E000299_HA471205F1C6F__44c27f4eae6de3
% rule_group_id: RG_ND168_D57_K3_DANG_KY_DOANH_NGHIEP
% doc_code: 168/2025/NĐ-CP
% source_ref: unit=UNIT_168_2025_N_CP_D57_K3_S1_SS1|doc_id=DOC_ND_DANG_KY_DOANH_NGHIEP_168_2025|chapter=V|section=|article=57|clause=3|point=|lines=592-592
% predicate_canonical: dang_ky_doanh_nghiep
% normalization_status: partial
% source_text: Doanh nghiệp không phải trả lệ phí đăng ký doanh nghiệp và phí công bố nội dung đăng ký doanh nghiệp trong trường hợp doanh nghiệp cập nhật, bổ sung thông tin sau:
applicability_condition(dang_ky_doanh_nghiep, 'trường hợp doanh nghiệp cập nhật, bổ sung thông tin sau') :-
    raw_condition('trường hợp doanh nghiệp cập nhật, bổ sung thông tin sau'),
    expression_condition(truong_hop_doanh_nghiep_cap_nhat_bo_sung_thong_tin_sau).

% rule_id: RULE_ND168_D59_K2_B_E000302_HB765E274CC42__6147c335fffb5f
% rule_group_id: RG_ND168_D59_K2_B_THANH_PHAN_HO_SO
% doc_code: 168/2025/NĐ-CP
% source_ref: unit=UNIT_168_2025_N_CP_D59_K2_B_S1_SS1|doc_id=DOC_ND_DANG_KY_DOANH_NGHIEP_168_2025|chapter=V|section=|article=59|clause=2|point=b|lines=602-602
% predicate_canonical: thanh_phan_ho_so
% normalization_status: full
% source_text: Doanh nghiệp phải đăng ký thay đổi nội dung đăng ký doanh nghiệp để phục vụ việc giải thể của doanh nghiệp theo quy định. Trong trường hợp này, hồ sơ đăng ký thay đổi phải kèm theo văn bản giải trình của doanh nghiệp về lý do đăng ký thay đ
dossier(thanh_phan_ho_so, '[\'kèm theo văn bản giải trình của doanh nghiệp về lý do đăng ký thay đổi và được Cơ quan đăng ký kinh doanh cấp tỉnh chấp thuận\']') :-
    applies_if('trường hợp này'),
    expression_condition(truong_hop_nay).

% rule_id: RULE_ND168_D59_K2_B_E000479_H6CE5F7A93C8B__e80d74b1b90e68
