% source_ref: unit=UNIT_168_2025_N_CP_D55_K3_S1_SS1|doc_id=DOC_ND_DANG_KY_DOANH_NGHIEP_168_2025|chapter=V|section=|article=55|clause=3|point=|lines=576-576
% predicate_canonical: trao_giay_tiep_nhan_ho_so
% normalization_status: full
% source_text: Sau khi tiếp nhận hồ sơ đăng ký doanh nghiệp, Cơ quan đăng ký kinh doanh cấp tỉnh trao giấy tiếp nhận hồ sơ và hẹn trả kết quả cho người nộp hồ sơ. Trong thời hạn 03 ngày làm việc kể từ ngày nhận hồ sơ, Cơ quan đăng ký kinh doanh cấp tỉnh x
legal_effect(co_quan_dang_ky_kinh_doanh_cap_tinh, cap_giay_chung_nhan_dang_ky_doanh_nghiep_giay_xac_nhan_ve_viec_thay_doi_noi_dung_dang_ky_doanh_nghiep_cho_doanh_nghiep) :-
    applies_if('khi tiếp nhận hồ sơ đăng ký doanh nghiệp, Cơ quan đăng ký kinh doanh'),
    expression_condition(khi_tiep_nhan_ho_so_dang_ky_doanh_nghiep_co_quan_dang_ky_kinh_doanh).

% rule_id: RULE_ND168_D55_K3_E000298_H1B18A16045A8__b3942ff77c087e
