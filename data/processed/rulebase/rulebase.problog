    unless('trừ trường hợp quy định tại điểm b khoản này'),
    expression_condition(doi_voi_doanh_nghiep_chi_nhanh_van_phong_dai_dien_dia_diem_kinh_doanh_co_dia_chi_tai_tinh_thanh_pho_truc_thuoc_trung_uong_trong_pham_vi_dia_phuong).

