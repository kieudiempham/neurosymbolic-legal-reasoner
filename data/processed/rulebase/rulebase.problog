% predicate_canonical: chiu_trach_nhiem
% normalization_status: full
% source_text: Thành viên hợp danh mới phải cùng liên đới chịu trách nhiệm bằng toàn bộ tài sản của mình đối với các khoản nợ và nghĩa vụ tài sản khác của công ty, trừ trường hợp thành viên đó và các thành viên còn lại có thỏa thuận khác.
applicability_condition(chiu_trach_nhiem, 'đối với các khoản nợ và nghĩa vụ tài sản khác của công ty') :-
    applies_if('đối với các khoản nợ và nghĩa vụ tài sản khác của công ty'),
    unless('trừ trường hợp thành viên đó và các thành viên còn lại có thỏa thuận khác'),
    expression_condition(doi_voi_cac_khoan_no_va_nghia_vu_tai_san_khac_cua_cong_ty).

