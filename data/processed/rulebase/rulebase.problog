% source_ref: unit=UNIT_168_2025_N_CP_D107_K4_S1_SS1|doc_id=DOC_ND_DANG_KY_DOANH_NGHIEP_168_2025|chapter=VIII|section=|article=107|clause=4|point=|lines=1004-1005
% predicate_canonical: thong_bao
% normalization_status: full
% source_text: Trường hợp hộ kinh doanh ngừng hoạt động kinh doanh tại địa chỉ đăng ký quá 06 tháng mà không thông báo với Cơ quan đăng ký kinh doanh cấp xã, Cơ quan thuế quản lý trực tiếp thì Cơ quan đăng ký kinh doanh cấp xã thông báo bằng văn bản về hà
deadline(thong_bao, 3.0, ngay_lam_viec, ke_tu_moc_tham_chieu) :-
    applies_if('Trường hợp hộ kinh doanh ngừng hoạt động kinh doanh tại địa chỉ đăng ký quá 06 tháng mà không'),
    expression_condition(truong_hop_ho_kinh_doanh_ngung_hoat_dong_kinh_doanh_tai_dia_chi_dang_ky_qua_06_thang_ma_khong).

% rule_id: RULE_ND168_D107_K4_E000501_HAD9534ACA4E3__b8fa4a2439ff62
% rule_group_id: RG_ND168_D107_K4_THONG_BAO
% doc_code: 168/2025/NĐ-CP
% source_ref: unit=UNIT_168_2025_N_CP_D107_K4_S1_SS1|doc_id=DOC_ND_DANG_KY_DOANH_NGHIEP_168_2025|chapter=VIII|section=|article=107|clause=4|point=|lines=1004-1005
% predicate_canonical: thong_bao
% normalization_status: full
% source_text: Trường hợp hộ kinh doanh ngừng hoạt động kinh doanh tại địa chỉ đăng ký quá 06 tháng mà không thông báo với Cơ quan đăng ký kinh doanh cấp xã, Cơ quan thuế quản lý trực tiếp thì Cơ quan đăng ký kinh doanh cấp xã thông báo bằng văn bản về hà
deadline(thong_bao, 3.0, ngay_lam_viec, ke_tu_moc_tham_chieu) :-
    applies_if('Trường hợp hộ kinh doanh ngừng hoạt động kinh doanh tại địa chỉ đăng ký quá 06 tháng mà không'),
    expression_condition(truong_hop_ho_kinh_doanh_ngung_hoat_dong_kinh_doanh_tai_dia_chi_dang_ky_qua_06_thang_ma_khong).

% rule_id: RULE_ND168_D107_K8_E000504_HE6BBDAF42D70__3340ce83b0c5f4
% rule_group_id: RG_ND168_D107_K8_CAP_NHAT_THONG_TIN
% doc_code: 168/2025/NĐ-CP
% source_ref: unit=UNIT_168_2025_N_CP_D107_K8_S1_SS1|doc_id=DOC_ND_DANG_KY_DOANH_NGHIEP_168_2025|chapter=VIII|section=|article=107|clause=8|point=|lines=1009-1009
% predicate_canonical: cap_nhat_thong_tin
% normalization_status: full
% source_text: Cơ quan đăng ký kinh doanh cấp xã ban hành quyết định thu hồi Giấy chứng nhận đăng ký hộ kinh doanh đồng thời ra thông báo về việc hộ kinh doanh đang làm thủ tục chấm dứt hoạt động, cập nhật tình trạng pháp lý của hộ kinh doanh sang tình tr
authority_action(co_quan_dang_ky_kinh_doanh, cap_nhat_thong_tin, dang_ky_doanh_nghiep) :-
    applies_if('trường hợp hộ kinh doanh bị thu hồi Giấy chứng nhận đăng ký hộ kinh doanh để thực hiện biện pháp cưỡng chế nợ thuế theo đề nghị của Cơ quan quản lý thuế'),
    unless('trừ trường hợp hộ kinh doanh bị thu hồi Giấy chứng nhận đăng ký hộ kinh doanh để thực hiện biện pháp cưỡng chế nợ thuế theo đề nghị của Cơ quan quản lý thuế'),
    expression_condition(truong_hop_ho_kinh_doanh_bi_thu_hoi_giay_chung_nhan_dang_ky_ho_kinh_doanh_de_thuc_hien_bien_phap_cuong_che_no_thue_theo_de_nghi_cua_co_quan_quan_ly_thue).

% rule_id: RULE_ND168_D107_K8_E000327_H9246BA7D11BB__dac16f19cbbcc1
