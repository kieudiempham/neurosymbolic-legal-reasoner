% predicate_canonical: nop_du_so_von_cam_ket_gop
% normalization_status: full
% source_text: Thành viên hợp danh hoặc thành viên góp vốn phải nộp đủ số vốn cam kết góp vào công ty trong thời hạn 15 ngày kể từ ngày được chấp thuận, trừ trường hợp Hội đồng thành viên quyết định thời hạn khác.
exception(nop_du_so_von_cam_ket_gop, 'trừ trường hợp Hội đồng thành viên quyết định thời hạn khác') :-
    applies_if('trường hợp Hội đồng thành viên quyết định thời hạn khác.'),
    expression_condition(truong_hop_hoi_dong_thanh_vien_quyet_dinh_thoi_han_khac).

