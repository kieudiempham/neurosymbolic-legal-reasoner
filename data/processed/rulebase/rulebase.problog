% predicate_canonical: thu_hoi_giay_chung_nhan_dang_ky_hoat_dong_chi_nhanh_van_phong_dai_dien_trong_thoi_han_03_ngay_lam_viec_ke_tu_ngay_ket_thuc_thoi_han_giai_trinh
% normalization_status: partial
% source_text: Trường hợp chi nhánh, văn phòng đại diện ngừng hoạt động trên 12 tháng mà không báo cho Cơ quan đăng ký kinh doanh cấp tỉnh và Cơ quan thuế thì Cơ quan đăng ký kinh doanh cấp tỉnh thông báo bằng văn bản về hành vi vi phạm và yêu cầu người đ
legal_effect(co_quan_dang_ky_kinh_doanh_cap_tinh, thu_hoi_giay_chung_nhan_dang_ky_hoat_dong_chi_nhanh_van_phong_dai_dien) :-
    applies_to(ap_dung_doi_voi_chi_nhanh_van_phong_dai_dien),
    raw_condition('Trường hợp chi nhánh, văn phòng đại diện ngừng hoạt động trên 12 tháng mà không báo cho Cơ quan đăng ký kinh doanh'),
    expression_condition(truong_hop_chi_nhanh_van_phong_dai_dien_ngung_hoat_dong_tren_12_thang_ma_khong_bao_cho_co_quan_dang_ky_kinh_doanh).

% rule_id: RULE_ND168_D71_K3_E000497_HD4B75A6952A5__7fe9ff563fe49f
% rule_group_id: RG_ND168_D71_K3_NG_KET_QUA_PHAP_LY
% doc_code: 168/2025/NĐ-CP
% source_ref: unit=UNIT_168_2025_N_CP_D71_K3_S1_SS1|doc_id=DOC_ND_DANG_KY_DOANH_NGHIEP_168_2025|chapter=VI|section=|article=71|clause=3|point=|lines=714-715
% predicate_canonical: chap_thuan_thi_co_quan_dang_ky_kinh_doanh_cap_tinh_ra_quyet_dinh_thu_hoi_giay_chung_nhan_dang_ky_hoat_dong_chi_nhanh_van_phong_dai_dien_trong_thoi_han_03_ngay_lam_viec_k
% normalization_status: partial
% source_text: Trường hợp chi nhánh, văn phòng đại diện ngừng hoạt động trên 12 tháng mà không báo cho Cơ quan đăng ký kinh doanh cấp tỉnh và Cơ quan thuế thì Cơ quan đăng ký kinh doanh cấp tỉnh thông báo bằng văn bản về hành vi vi phạm và yêu cầu người đ
legal_effect(co_quan_dang_ky_kinh_doanh_cap_tinh, 'chấp thuận thì Cơ quan đăng ký kinh doanh cấp tỉnh ra quyết định thu hồi Giấy chứng nhận đăng ký hoạt động chi nhánh, văn phòng đại diện trong thời hạn 03 ngày làm việc k') :-
    applies_to(ap_dung_doi_voi_chi_nhanh_van_phong_dai_dien),
    raw_condition('Trường hợp chi nhánh, văn phòng đại diện ngừng hoạt động trên 12 tháng mà không báo cho Cơ quan đăng ký kinh doanh'),
    expression_condition(truong_hop_chi_nhanh_van_phong_dai_dien_ngung_hoat_dong_tren_12_thang_ma_khong_bao_cho_co_quan_dang_ky_kinh_doanh).

